# Chotgor Backend Environment Variables

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API Key (optional - for web search tool)
TAVILY_API_KEY=tvly-...

# OpenRouter API Key (optional - access to many models via openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# Database paths (relative to /app/data in container)
SQLITE_DB_PATH=/app/data/chotgor.db
LANCE_DB_PATH=/app/data/lancedb

# Server settings
HOST=0.0.0.0
PORT=8000

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6
