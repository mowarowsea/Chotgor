# Chotgor Backend Environment Variables

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API Key (optional - for web search tool)
TAVILY_API_KEY=tvly-...

# Database paths (relative to /app/data in container)
SQLITE_DB_PATH=/app/data/chotgor.db
CHROMA_DB_PATH=/app/data/chroma

# Server settings
HOST=0.0.0.0
PORT=8000

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# ChromaDB embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
